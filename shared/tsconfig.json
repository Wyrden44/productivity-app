{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": ".",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"]
}
