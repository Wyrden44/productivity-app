{
    "name": "backend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "type-check": "",
        "test:db:up": "docker compose -f docker-compose.test.yml --env-file .env.test up -d --wait",
        "test:db:down": "docker compose -f docker-compose.test.yml down -v",
        "test:migrate": "dotenv -e .env.test -- prisma migrate deploy",
        "test": "npm run test:db:up && npm run test:migrate && vitest && npm run test:db:down",
        "docker:dev": "docker compose -f docker-compose.dev.yml up",
        "docker:down": "docker compose -f docker-compose.dev.yml down"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@productivity/shared": "file:../shared",
        "@types/jsonwebtoken": "^9.0.10",
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.3.1",
        "next": "16.1.6",
        "next-auth": "^5.0.0-beta.30",
        "pg": "^8.19.0",
        "prisma": "^7.4.2",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.0.18",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "prettier": "3.8.1",
        "supertest": "^7.2.2",
        "typescript": "^5",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    }
}
