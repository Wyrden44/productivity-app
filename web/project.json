{
    "name": "web",
    "$schema": "../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "web/src",
    "// targets": "to see all targets run: nx show project web --web",
    "targets": {
        "type-check": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vue-tsc -p web/tsconfig.app.json --noEmit"
            }
        }
    }
}
